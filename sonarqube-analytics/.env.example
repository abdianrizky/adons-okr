# SonarQube Configuration
# Copy this file to .env and fill in your actual token

# SonarQube Server URL
SONAR_URL=https://sonar.infra.paper.id

# SonarQube Authentication Token
# Get your token from: https://sonar.infra.paper.id → My Account → Security → Generate Token
SONAR_TOKEN=

# Project Keys
PROJECT_PAYMENT_BACKEND=paper-payment-backend
PROJECT_DOCUMENT=paper-document

# Date Range for Historical Data
DATE_FROM=2025-07-01
DATE_TO=2025-12-31
